---
const currentYear = new Date().getFullYear();
---

<footer class="bg-surface border-t border-border mt-20">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8">
      <div>
        <h3 class="font-bold text-text mb-3">Cameron Reismueller</h3>
        <p class="text-sm text-text-muted leading-relaxed">
          Climbing instructor offering guided climbs, courses, and private instruction for all skill levels.
        </p>
      </div>

      <div>
        <h3 class="font-bold text-text mb-3">Links</h3>
        <ul class="space-y-2 text-sm">
          <li><a href="/services" class="text-text-muted hover:text-primary transition-colors">Services</a></li>
          <li><a href="/blog" class="text-text-muted hover:text-primary transition-colors">Blog</a></li>
          <li><a href="/book" class="text-text-muted hover:text-primary transition-colors">Get in Touch</a></li>
        </ul>
      </div>

      <div>
        <h3 class="font-bold text-text mb-3">Connect</h3>
        <ul class="space-y-2 text-sm">
          <!-- TODO: Add actual social links -->
          <li><a href="https://instagram.com/" class="text-text-muted hover:text-primary transition-colors" target="_blank" rel="noopener">Instagram</a></li>
          <li><a href="https://youtube.com/" class="text-text-muted hover:text-primary transition-colors" target="_blank" rel="noopener">YouTube</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-10 pt-6 border-t border-border text-center text-sm text-text-muted">
      &copy; {currentYear} Cameron Reismueller. All rights reserved.
    </div>
  </div>
</footer>
