---
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services/', label: 'Services' },
  { href: '/blog/', label: 'Blog' },
  { href: '/book/', label: 'Get in Touch' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-border">
  <nav class="max-w-5xl mx-auto px-4 sm:px-6 py-4 flex items-center justify-between">
    <a href="/" class="shrink-0 transition-opacity hover:opacity-90" aria-label="Sunrise Climbing Adventures">
      <img
        src="/sunrise-logo.png"
        alt="Sunrise Climbing Adventures"
        class="h-12 w-auto sm:h-16"
      />
    </a>

    <!-- Mobile menu button -->
    <button
      id="mobile-menu-btn"
      class="sm:hidden p-2 text-text-muted hover:text-text"
      aria-label="Toggle menu"
    >
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>

    <!-- Desktop nav -->
    <ul class="hidden sm:flex items-center gap-6">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'text-sm font-medium transition-colors',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-primary'
                : 'text-text-muted hover:text-text',
              label === 'Get in Touch' && 'bg-primary text-white px-4 py-2 rounded-lg hover:bg-primary-dark hover:text-white',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Mobile nav -->
  <div id="mobile-menu" class="hidden sm:hidden border-t border-border">
    <ul class="px-4 py-3 space-y-2">
      {navLinks.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              'block py-2 text-sm font-medium transition-colors',
              currentPath === href || (href !== '/' && currentPath.startsWith(href))
                ? 'text-primary'
                : 'text-text-muted hover:text-text',
              label === 'Get in Touch' && 'bg-primary text-white px-4 py-2 rounded-lg text-center hover:bg-primary-dark hover:text-white',
            ]}
          >
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
