---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://climbtrad.com/' },
    { '@type': 'ListItem', position: 2, name: 'Get in Touch', item: 'https://climbtrad.com/book/' },
  ],
};
---

<BaseLayout
  title="Get in Touch — Sunrise Climbing"
  description="Call Cameron to set up a climbing lesson, guided day, or trad course in Southern California."
  schemas={[breadcrumbSchema]}
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12 sm:pt-24 sm:pb-16">
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text">Get in Touch</span>
    </nav>

    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-text mb-6">
        Let's talk
      </h1>
      <p class="text-lg text-text-muted leading-relaxed mb-12">
        Easiest thing is to just give me a call. We'll chat about what you're looking for and go from there.
      </p>

      <!-- Phone CTA -->
      <div class="bg-surface rounded-2xl border border-border p-8 sm:p-12 mb-12">
        <h2 class="text-2xl font-bold text-text mb-3">Call or text</h2>
        <p class="text-text-muted mb-6">
          Tell me a bit about yourself and what you want to do. I'll take it from there.
        </p>
        <a
          href="tel:+17142449286"
          class="inline-flex items-center justify-center bg-primary text-white text-xl font-bold px-8 py-4 rounded-xl hover:bg-primary-dark transition-colors"
        >
          (714) 244-9286
        </a>
        <p class="text-sm text-text-muted mt-4">
          If I don't pick up, leave a message or shoot me a text — I'll get back to you.
        </p>
      </div>

      <!-- What to expect -->
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-text mb-6">How it works</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="bg-surface rounded-xl p-5 border border-border">
            <div class="text-primary font-bold text-lg mb-2">1</div>
            <h3 class="font-semibold text-text mb-1">Quick chat</h3>
            <p class="text-sm text-text-muted">Tell me about your experience and what you want to work on.</p>
          </div>
          <div class="bg-surface rounded-xl p-5 border border-border">
            <div class="text-primary font-bold text-lg mb-2">2</div>
            <h3 class="font-semibold text-text mb-1">I'll make a plan</h3>
            <p class="text-sm text-text-muted">I'll pick the right crag and put together a session that fits your goals.</p>
          </div>
          <div class="bg-surface rounded-xl p-5 border border-border">
            <div class="text-primary font-bold text-lg mb-2">3</div>
            <h3 class="font-semibold text-text mb-1">We go climb</h3>
            <p class="text-sm text-text-muted">Show up, and I'll handle the rest. Gear, logistics, everything.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
