---
import BaseLayout from '../layouts/BaseLayout.astro';

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cameronreismueller.com' },
    { '@type': 'ListItem', position: 2, name: 'Get in Touch', item: 'https://cameronreismueller.com/book' },
  ],
};
---

<BaseLayout
  title="Get in Touch — Cameron Reismueller, Climbing Instructor"
  description="Contact Cameron Reismueller to book climbing lessons, guided climbs, or multi-day courses. Call to discuss your goals and schedule a session."
  schemas={[breadcrumbSchema]}
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12 sm:pt-24 sm:pb-16">
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text">Get in Touch</span>
    </nav>

    <div class="max-w-2xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold text-text mb-6">
        Get in Touch
      </h1>
      <p class="text-lg text-text-muted leading-relaxed mb-12">
        The best way to get started is a quick phone call. We'll talk about your experience, goals, and schedule — and I'll recommend the right session for you.
      </p>

      <!-- Phone CTA -->
      <div class="bg-surface rounded-2xl border border-border p-8 sm:p-12 mb-12">
        <h2 class="text-2xl font-bold text-text mb-3">Call Me</h2>
        <p class="text-text-muted mb-6">
          Give me a ring to chat about your climbing goals and set up a session.
        </p>
        <!-- TODO: Replace with actual phone number -->
        <a
          href="tel:+1XXXXXXXXXX"
          class="inline-flex items-center justify-center bg-primary text-white text-xl font-bold px-8 py-4 rounded-xl hover:bg-primary-dark transition-colors"
        >
          (XXX) XXX-XXXX
        </a>
        <p class="text-sm text-text-muted mt-4">
          If I don't pick up, leave a message and I'll call you back within the day.
        </p>
      </div>

      <!-- What to expect -->
      <div class="max-w-2xl mx-auto">
        <h2 class="text-2xl font-bold text-text mb-6">What to Expect</h2>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
          <div class="bg-surface rounded-xl p-5 border border-border">
            <div class="text-primary font-bold text-lg mb-2">1</div>
            <h3 class="font-semibold text-text mb-1">Quick Chat</h3>
            <p class="text-sm text-text-muted">Tell me about your experience level and what you want to work on.</p>
          </div>
          <div class="bg-surface rounded-xl p-5 border border-border">
            <div class="text-primary font-bold text-lg mb-2">2</div>
            <h3 class="font-semibold text-text mb-1">Right Session</h3>
            <p class="text-sm text-text-muted">I'll recommend the best lesson or guided day for your goals.</p>
          </div>
          <div class="bg-surface rounded-xl p-5 border border-border">
            <div class="text-primary font-bold text-lg mb-2">3</div>
            <h3 class="font-semibold text-text mb-1">Set a Date</h3>
            <p class="text-sm text-text-muted">We'll pick a day that works and I'll send you everything you need to know.</p>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
