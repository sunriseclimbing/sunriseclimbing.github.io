---
import BaseLayout from "../layouts/BaseLayout.astro";

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Cameron Reismueller",
  url: "https://climbtrad.com/",
  jobTitle: "Climbing Guide & Instructor",
  knowsAbout: [
    "Rock Climbing",
    "Sport Climbing",
    "Trad Climbing",
    "Climbing Safety",
    "Southern California Climbing",
  ],
  sameAs: [],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Sunrise Climbing — Cameron Reismueller",
  url: "https://climbtrad.com/",
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: "Do I need climbing experience to book a session?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Not at all. A lot of my clients are brand new to climbing. I bring all the gear and walk you through everything from the ground up.",
      },
    },
    {
      "@type": "Question",
      name: "What gear do I need to bring?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "If you're just getting started, I have everything you need — harness, helmet, shoes. Just show up in clothes you can move in and bring water. If you have your own gear, bring it and we'll talk through your setup.",
      },
    },
    {
      "@type": "Question",
      name: "Where do you climb?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "All over Southern California — Joshua Tree, Malibu Creek, Stoney Point, Tahquitz, the list goes on. I grew up climbing these spots and I'll pick the right one based on what we're working on and your comfort level.",
      },
    },
    {
      "@type": "Question",
      name: "How do I book?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "Just give me a call at (714) 244-9286. We'll have a quick conversation about what you're looking for and find a day that works.",
      },
    },
  ],
};

const services = [
  {
    id: "beginner-lessons",
    title: "Learn to Climb Outside",
    description: "Whether you're brand new to climbing or a beanie-wearing-boulder-bro, you'll get a feel for real rock.",
  },
  {
    id: "sport-climbing",
    title: "Sport Climbing",
    description: "Ready to lead the pitch outside? You'll learn how to confidently clip, climb, and clean routes.",
  },
  {
    id: "trad-climbing",
    title: "Trad Climbing",
    description: "Learn to place solid gear and build confidence-inspiring anchors, utilizing modern techniques and systems.",
  },
  {
    id: "private-guiding",
    title: "Guided Days",
    description: "For more experienced climbers wanting insider info and guidance on SoCal's best crags and big walls. I'll plan a day for us based on your ability.",
  },
];
---

<BaseLayout
  title="Sunrise Climbing — Trad & Sport Climbing Instruction in Southern California"
  description="Cameron Reissmueller is a climbing guide based in LA and OC with over 10 years of experience. Trad and sport climbing instruction, guided days, and beginner lessons across Southern California."
  schemas={[personSchema, websiteSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="max-w-3xl">
      <p class="text-primary font-semibold mb-3">Los Angeles, CA</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-text leading-tight mb-6">
        Explore trad climbing in <span class="text-primary">Southern California</span>
      </h1>
      <p class="text-lg text-text-muted leading-relaxed mb-8 max-w-2xl">
        Every day is an opportunity for a fresh start and a new adventure. Whether you're looking to climb for the first time or develop the skills you have, Sunrise Climbing provides a safe place to help facilitate your growth on and off the wall.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="tel:+17142449286"
          class="inline-flex items-center justify-center bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
        >
          Call (714) 244-9286
        </a>
        <a
          href="/services/"
          class="inline-flex items-center justify-center border border-border text-text px-6 py-3 rounded-lg font-medium hover:bg-surface transition-colors"
        >
          What I Offer
        </a>
      </div>
    </div>
  </section>

  <!-- What I Offer -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-text mb-4">What I Offer</h2>
      <p class="text-text-muted mb-10 max-w-2xl">
        My goal is for you to show up with only your intention to learn something new and I'll provide everything else - gear, plan, instruction - in a way that adapts to your ability.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a href={`/services/#${service.id}`} class="group bg-white rounded-xl p-6 border border-border hover:border-primary/30 hover:shadow-sm transition-all">
            <h3 class="font-semibold text-text mb-2 group-hover:text-primary transition-colors">{service.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <h2 class="text-3xl font-bold text-text mb-10">Common Questions</h2>
    <div class="space-y-6 max-w-3xl">
      <div>
        <h3 class="font-semibold text-text mb-2">Do I need climbing experience?</h3>
        <p class="text-text-muted leading-relaxed">
          Not at all. A lot of my clients are brand new to climbing. I bring all the gear and walk you through everything from the ground up.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">What gear do I need?</h3>
        <p class="text-text-muted leading-relaxed">
          If you're just getting started, I have everything you need — harness, helmet, shoes. Just show up in clothes you can move in and bring water. If you have your own gear, bring it and we'll talk through your setup.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">Where do you climb?</h3>
        <p class="text-text-muted leading-relaxed">
          All over Southern California — Joshua Tree, Malibu Creek, Stoney Point, Tahquitz, the list goes on. I'll pick the right one based on what we're working on and your comfort level.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">How do I book?</h3>
        <p class="text-text-muted leading-relaxed">
          Just give me a <a href="tel:+17142449286" class="text-primary hover:underline">call</a>. We'll have a quick conversation about what you're looking for and find a day that works.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-bold text-text mb-4">Book your climbing experience today</h2>
      <p class="text-text-muted mb-8 max-w-xl mx-auto">
        Give me a call or send me a text and we'll figure out a plan tailored to you.
      </p>
      <a
        href="tel:+17142449286"
        class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
      >
        (714) 244-9286
      </a>
    </div>
  </section>
</BaseLayout>
