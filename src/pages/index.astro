---
import BaseLayout from '../layouts/BaseLayout.astro';

const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Cameron Reismueller',
  url: 'https://cameronreismueller.com',
  jobTitle: 'Climbing Instructor',
  knowsAbout: [
    'Rock Climbing',
    'Sport Climbing',
    'Trad Climbing',
    'Climbing Safety',
    'Outdoor Education',
  ],
  sameAs: [
    // TODO: Add social profile URLs
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Cameron Reismueller — Climbing Instructor',
  url: 'https://cameronreismueller.com',
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: [
    {
      '@type': 'Question',
      name: 'Do I need climbing experience to take a lesson?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'No prior experience is needed. I offer beginner-friendly sessions that cover all the fundamentals — gear, knots, belaying, movement technique, and safety. You will be climbing confidently by the end of your first session.',
      },
    },
    {
      '@type': 'Question',
      name: 'What gear do I need to bring?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'For introductory sessions, all technical gear is provided including harness, helmet, and climbing shoes. Just wear comfortable athletic clothing and bring water. For advanced clients, bring your own gear and we can discuss specifics when you call.',
      },
    },
    {
      '@type': 'Question',
      name: 'What types of climbing instruction do you offer?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'I offer instruction in sport climbing and trad climbing. Sessions range from single introductory lessons to multi-day courses covering lead climbing, anchor building, and self-rescue.',
      },
    },
    {
      '@type': 'Question',
      name: 'How do I book a climbing session?',
      acceptedAnswer: {
        '@type': 'Answer',
        text: 'Give me a call to discuss your goals, experience level, and schedule. I will recommend the right session type and we can set up a date that works for you.',
      },
    },
  ],
};

const services = [
  {
    id: 'beginner-lessons',
    title: 'Beginner Lessons',
    description: 'Learn the fundamentals — knots, belaying, movement, and safety — in a supportive, confidence-building environment.',
  },
  {
    id: 'sport-climbing',
    title: 'Sport Climbing',
    description: 'Improve your lead climbing, clipping technique, and route-reading on bolted outdoor routes.',
  },
  {
    id: 'trad-climbing',
    title: 'Trad Climbing',
    description: 'Master gear placement, anchor building, and crack climbing with hands-on trad instruction.',
  },
  {
    id: 'private-guiding',
    title: 'Private Guiding',
    description: 'Custom guided climbing days tailored to your goals — from your first outdoor climb to your next project.',
  },
];
---

<BaseLayout
  title="Cameron Reismueller — Climbing Instructor | Lessons, Guiding & Courses"
  description="Professional climbing instructor offering beginner lessons, sport and trad climbing instruction, and private guiding for all skill levels."
  schemas={[personSchema, websiteSchema, faqSchema]}
>
  <!-- Hero -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-20 sm:pt-24 sm:pb-28">
    <div class="max-w-3xl">
      <p class="text-primary font-semibold mb-3">Climbing Instructor</p>
      <h1 class="text-4xl sm:text-5xl font-bold text-text leading-tight mb-6">
        Climb higher with <span class="text-primary">confidence and skill</span>
      </h1>
      <p class="text-lg text-text-muted leading-relaxed mb-8 max-w-2xl">
        Whether you're touching rock for the first time or pushing into trad terrain, I provide hands-on instruction that builds real skills, safe habits, and lasting confidence on the wall.
      </p>
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="/book"
          class="inline-flex items-center justify-center bg-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
        >
          Get in Touch
        </a>
        <a
          href="/services"
          class="inline-flex items-center justify-center border border-border text-text px-6 py-3 rounded-lg font-medium hover:bg-surface transition-colors"
        >
          View Services
        </a>
      </div>
    </div>
  </section>

  <!-- What I Offer -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-text mb-4">What I Offer</h2>
      <p class="text-text-muted mb-10 max-w-2xl">
        Instruction for every level — from first-time climbers to experienced leaders looking to expand their skills.
      </p>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a href={`/services#${service.id}`} class="group bg-white rounded-xl p-6 border border-border hover:border-primary/30 hover:shadow-sm transition-all">
            <h3 class="font-semibold text-text mb-2 group-hover:text-primary transition-colors">{service.title}</h3>
            <p class="text-sm text-text-muted leading-relaxed">{service.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section (AIEO optimized) -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <h2 class="text-3xl font-bold text-text mb-10">Frequently Asked Questions</h2>
    <div class="space-y-6 max-w-3xl">
      <div>
        <h3 class="font-semibold text-text mb-2">Do I need climbing experience to take a lesson?</h3>
        <p class="text-text-muted leading-relaxed">
          No prior experience is needed. I offer beginner-friendly sessions that cover all the fundamentals — gear, knots, belaying, movement technique, and safety. You'll be climbing confidently by the end of your first session.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">What gear do I need to bring?</h3>
        <p class="text-text-muted leading-relaxed">
          For introductory sessions, all technical gear is provided including harness, helmet, and climbing shoes. Just wear comfortable athletic clothing and bring water. For advanced clients, bring your own gear and we can discuss specifics when you call.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">What types of climbing instruction do you offer?</h3>
        <p class="text-text-muted leading-relaxed">
          I offer instruction in sport climbing and trad climbing. Sessions range from single introductory lessons to multi-day courses covering lead climbing, anchor building, and self-rescue.
        </p>
      </div>
      <div>
        <h3 class="font-semibold text-text mb-2">How do I book a climbing session?</h3>
        <p class="text-text-muted leading-relaxed">
          Give me a <a href="/book" class="text-primary hover:underline">call</a> to discuss your goals, experience level, and schedule. I'll recommend the right session type and we can set up a date that works for you.
        </p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-surface py-16 sm:py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-3xl font-bold text-text mb-4">Ready to get on the rock?</h2>
      <p class="text-text-muted mb-8 max-w-xl mx-auto">
        Give me a call to talk about your climbing goals. I'll help you figure out the right next step.
      </p>
      <a
        href="/book"
        class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
      >
        Get in Touch
      </a>
    </div>
  </section>
</BaseLayout>
