---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cameronreismueller.com' },
    { '@type': 'ListItem', position: 2, name: 'Blog', item: 'https://cameronreismueller.com/blog' },
  ],
};
---

<BaseLayout
  title="Blog — Climbing Tips, Technique & Stories | Cameron Reismueller"
  description="Articles on climbing technique, training, gear, safety, and outdoor adventure — from a working climbing instructor."
  schemas={[breadcrumbSchema]}
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12 sm:pt-24 sm:pb-16">
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text">Blog</span>
    </nav>

    <h1 class="text-4xl sm:text-5xl font-bold text-text mb-6">Blog</h1>
    <p class="text-lg text-text-muted leading-relaxed max-w-2xl mb-12">
      Tips, technique breakdowns, and stories from the rock.
    </p>

    {posts.length === 0 ? (
      <p class="text-text-muted">Posts coming soon.</p>
    ) : (
      <div class="space-y-8">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="group block bg-surface rounded-xl p-6 border border-border hover:border-primary/30 hover:shadow-sm transition-all">
            <time class="text-sm text-text-muted" datetime={post.data.date.toISOString()}>
              {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
            </time>
            <h2 class="text-xl font-bold text-text mt-2 mb-2 group-hover:text-primary transition-colors">
              {post.data.title}
            </h2>
            <p class="text-text-muted leading-relaxed">{post.data.description}</p>
            {post.data.tags.length > 0 && (
              <div class="flex flex-wrap gap-2 mt-3">
                {post.data.tags.map((tag: string) => (
                  <span class="text-xs bg-white border border-border rounded-full px-3 py-1 text-text-muted">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
