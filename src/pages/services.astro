---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: {
    '@type': 'Person',
    name: 'Cameron Reismueller',
    url: 'https://cameronreismueller.com',
  },
  serviceType: 'Climbing Instruction & Guiding',
  areaServed: {
    '@type': 'Place',
    name: 'Worldwide',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Climbing Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Beginner Climbing Lessons',
          description: 'Introduction to climbing fundamentals including safety, belaying, knots, and movement technique.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Sport Climbing Instruction',
          description: 'Lead climbing technique, clipping, and outdoor sport climbing skills.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Trad Climbing Instruction',
          description: 'Gear placement, anchor building, and traditional climbing skills.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Private Guiding',
          description: 'Custom guided climbing days for individuals and small groups.',
        },
      },
    ],
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://cameronreismueller.com' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://cameronreismueller.com/services' },
  ],
};

const services = [
  {
    id: 'beginner-lessons',
    title: 'Beginner Climbing Lessons',
    description: 'Never climbed before? No problem. I will get you comfortable on the wall with a patient, safety-first approach. By the end of your first session you will know how to tie in, belay a partner, and move efficiently on rock.',
    capabilities: [
      'Harness fitting and gear orientation',
      'Essential knots (figure-eight, clove hitch)',
      'Belay technique and communication',
      'Footwork and body positioning fundamentals',
      'Indoor-to-outdoor transition guidance',
    ],
  },
  {
    id: 'sport-climbing',
    title: 'Sport Climbing',
    description: 'Take your climbing outside on bolted routes. I cover everything from your first lead to pushing grades — clipping technique, route reading, falling practice, and mental skills for committing moves above your last bolt.',
    capabilities: [
      'Lead climbing technique and clipping',
      'Route reading and beta analysis',
      'Fall practice and fear management',
      'Redpoint and onsight strategies',
      'Outdoor ethics and crag etiquette',
    ],
  },
  {
    id: 'trad-climbing',
    title: 'Trad Climbing',
    description: 'Learn to place your own protection and build solid anchors. Trad climbing is the most self-reliant form of roped climbing, and I teach it with an emphasis on sound judgment and clean technique.',
    capabilities: [
      'Passive and active protection placement',
      'Anchor building (natural and gear)',
      'Crack climbing technique (hand, fist, finger, off-width)',
      'Rope management and seconding technique',
      'Self-rescue fundamentals',
    ],
  },
  {
    id: 'private-guiding',
    title: 'Private Guiding',
    description: 'A fully customized day on the rock tailored to your goals. Whether it is your first outdoor climb, a specific route you have been eyeing, or a skills refresher — I plan the day around what you want to get out of it.',
    capabilities: [
      'Custom itinerary based on your goals',
      'Flexible scheduling for individuals or small groups',
      'All technical gear provided for beginners',
      'Photo and video of your climbing day',
      'Post-session debrief and progression recommendations',
    ],
  },
];
---

<BaseLayout
  title="Climbing Services — Lessons, Guiding & Courses | Cameron Reismueller"
  description="Professional climbing instruction: beginner lessons, sport and trad climbing courses, and private guiding for all levels."
  schemas={[serviceSchema, breadcrumbSchema]}
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12 sm:pt-24 sm:pb-16">
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text">Services</span>
    </nav>

    <h1 class="text-4xl sm:text-5xl font-bold text-text mb-6">
      Climbing Services
    </h1>
    <p class="text-lg text-text-muted leading-relaxed max-w-2xl mb-16">
      Whether you are just starting out or looking to push your limits, I offer instruction and guiding tailored to where you are and where you want to go.
    </p>

    <div class="space-y-12">
      {services.map((service) => (
        <div id={service.id} class="bg-surface rounded-xl p-6 sm:p-8 border border-border scroll-mt-20">
          <h2 class="text-2xl font-bold text-text mb-3">{service.title}</h2>
          <p class="text-text-muted leading-relaxed mb-5">{service.description}</p>
          <ul class="space-y-2">
            {service.capabilities.map((cap) => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <span class="text-primary mt-0.5 shrink-0">&#x2713;</span>
                {cap}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 text-center">
    <h2 class="text-3xl font-bold text-text mb-4">Ready to climb?</h2>
    <p class="text-text-muted mb-8 max-w-xl mx-auto">
      Give me a call and let's figure out the right session for you. No commitment — just a conversation about your goals.
    </p>
    <a
      href="/book"
      class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
    >
      Get in Touch
    </a>
  </section>
</BaseLayout>
