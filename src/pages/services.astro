---
import BaseLayout from '../layouts/BaseLayout.astro';

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  provider: {
    '@type': 'Person',
    name: 'Cameron Reismueller',
    url: 'https://climbtrad.com/',
  },
  serviceType: 'Climbing Instruction & Guiding',
  areaServed: {
    '@type': 'Place',
    name: 'Southern California',
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Climbing Services',
    itemListElement: [
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Beginner Climbing Lessons',
          description: 'Learn the fundamentals of climbing: knots, belaying, movement, and safety.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Sport Climbing Instruction',
          description: 'Lead climbing, clipping technique, and outdoor sport climbing skills.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Trad Climbing Instruction',
          description: 'Gear placement, anchor building, and traditional climbing skills.',
        },
      },
      {
        '@type': 'Offer',
        itemOffered: {
          '@type': 'Service',
          name: 'Guided Days',
          description: 'Custom guided climbing days at crags across Southern California.',
        },
      },
    ],
  },
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://climbtrad.com/' },
    { '@type': 'ListItem', position: 2, name: 'Services', item: 'https://climbtrad.com/services/' },
  ],
};

const services = [
  {
    id: 'beginner-lessons',
    title: 'Intro to Outdoor Climbing',
    description: 'You don\'t need to know anything coming in. I\'ll teach you how to tie in, belay, and move on rock. We\'ll go at your pace, and by the end of the day you\'ll have a solid foundation to build on.',
    capabilities: [
      'Harness fitting and gear basics',
      'Knots and hitches',
      'Belay technique and partner communication',
      'Footwork and body positioning on rock',
      'Making the jump from the gym to outdoor climbing',
    ],
  },
  {
    id: 'sport-climbing',
    title: 'Sport Climbing',
    description: 'If you\'ve been top-roping and want to start leading on bolts, or you\'re already leading and want to climb harder outside, this is for you. There\'s no shortage of great sport routes out here.',
    capabilities: [
      'Lead climbing and clipping technique',
      'Reading routes from the ground',
      'Practicing falls so they feel less scary',
      'Strategies for redpointing and onsighting',
    ],
  },
  {
    id: 'trad-climbing',
    title: 'Trad Climbing',
    description: 'This is the stuff I get most excited about. Trad climbing means placing your own protection and relying on your own judgment. It\'s the most self-reliant way to climb and there\'s nothing quite like it. I\'ll teach you to build solid anchors, place gear you can trust, and climb cracks from fingers to fists. Southern California is home to some world-class trad climbing within a 2 hour radius of LA/OC',
    capabilities: [
      'Placing cams, nuts, and other protection',
      'Anchor Building',
      'Crack climbing',
      'Rope Management',
      'Self-rescue basics',
    ],
  },
  {
    id: 'private-guiding',
    title: 'Guided Days',
    description: 'Maybe you just want to get outside and climb without worrying about the logistics. Tell me what sounds fun — a day at Joshua Tree, some routes at Malibu Creek, a trip out to Tahquitz — and I\'ll handle the planning. Good for first-timers, visiting climbers, or anyone who wants a local who knows the spots.',
    capabilities: [
      'I\'ll pick the crag and routes based on your goals',
      'Flexible scheduling',
      'All gear provided if you need it',
      'Photos of your day on the rock',
      'Tips on what to work on next',
    ],
  },
];
---

<BaseLayout
  title="Climbing Services — Lessons, Trad, Sport & Guided Days | Sunrise Climbing"
  description="Climbing instruction and guided days across Southern California. Beginner lessons, sport climbing, trad climbing, and custom guided days from a local with 10 years of experience."
  schemas={[serviceSchema, breadcrumbSchema]}
>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 pt-16 pb-12 sm:pt-24 sm:pb-16">
    <nav class="text-sm text-text-muted mb-8">
      <a href="/" class="hover:text-primary transition-colors">Home</a>
      <span class="mx-2">/</span>
      <span class="text-text">Services</span>
    </nav>

    <h1 class="text-4xl sm:text-5xl font-bold text-text mb-6">
      What I Offer
    </h1>
    <p class="text-lg text-text-muted leading-relaxed max-w-2xl mb-16">
      I've been climbing all over Southern California for over a decade. I know the crags, the approaches, and I'll tailor the day to what you actually want to work on.
    </p>

    <div class="space-y-12">
      {services.map((service) => (
        <div id={service.id} class="bg-surface rounded-xl p-6 sm:p-8 border border-border scroll-mt-20">
          <h2 class="text-2xl font-bold text-text mb-3">{service.title}</h2>
          <p class="text-text-muted leading-relaxed mb-5">{service.description}</p>
          <ul class="space-y-2">
            {service.capabilities.map((cap) => (
              <li class="flex items-start gap-2 text-sm text-text-muted">
                <span class="text-primary mt-0.5 shrink-0">&#x2713;</span>
                {cap}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16 text-center">
    <h2 class="text-3xl font-bold text-text mb-4">Sounds good?</h2>
    <p class="text-text-muted mb-8 max-w-xl mx-auto">
      Give me a call and we'll figure out the right plan for you.
    </p>
    <a
      href="tel:+17142449286"
      class="inline-flex items-center justify-center bg-primary text-white px-8 py-3 rounded-lg font-medium hover:bg-primary-dark transition-colors"
    >
      (714) 244-9286
    </a>
  </section>
</BaseLayout>
